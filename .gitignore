# --------------------------------------------------------------
# Dependencies & build output
# --------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

.next/
out/
build/
dist/
coverage/
*.tsbuildinfo
next-env.d.ts

# --------------------------------------------------------------
# Logs
# --------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --------------------------------------------------------------
# Environment files — NEVER commit secrets.
# `.env.local.example` is allow-listed because it's a sample with no real values.
# --------------------------------------------------------------
.env
.env.*
!.env.example
!.env.local.example

# --------------------------------------------------------------
# Local data store (SQLite)
# --------------------------------------------------------------
data/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# --------------------------------------------------------------
# OS & editors
# --------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# --------------------------------------------------------------
# Tooling / harness state (per-machine; may contain secrets in
# command-permission caches — never commit).
# --------------------------------------------------------------
.claude/
.cursor/

# --------------------------------------------------------------
# Deploy / cloud caches
# --------------------------------------------------------------
.vercel/

# --------------------------------------------------------------
# Keys / credentials
# --------------------------------------------------------------
*.pem
*.key
*.p12
*.pfx

# --------------------------------------------------------------
# Misc
# --------------------------------------------------------------
.tmp/
tmp/

# Local email template previews — regenerated via lib/email.ts.
email-preview-*.html
