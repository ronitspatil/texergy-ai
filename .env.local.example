# ------------------------------------------------------------------
# Texergy AI — environment template
# Copy to .env.local and fill in. .env.local is gitignored.
# Generate strong tokens:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
# ------------------------------------------------------------------

# Required: Supabase project (server-side, bypasses RLS).
# Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Required: gates the /admin/waitlist viewer.
ADMIN_TOKEN=replace-with-a-long-random-string

# Required: salt for hashing client IPs before storing in DB.
# Rotating this invalidates the in-memory rate-limit cache only.
IP_HASH_SALT=replace-with-a-different-long-random-string

# ---- Optional: confirmation emails via Resend (https://resend.com) ----
# Both must be set for emails to send. If unset, the API still succeeds —
# emails are simply skipped (logged as a warning).
# RESEND_API_KEY=re_...
# WAITLIST_FROM_EMAIL=Texergy AI <hello@texergy.ai>
# WAITLIST_REPLY_TO=hello@texergy.ai
